<?xml version="1.0"?>
<rdf:RDF xmlns="http://protege.stanford.edu/ontologies/grocery-ontology/"
     xml:base="http://protege.stanford.edu/ontologies/grocery-ontology/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:grocery-ontology="http://protege.stanford.edu/ontologies/grocery-ontology#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:wgs84_pos="http://www.w3.org/2003/01/geo/wgs84_pos#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/">
    <owl:Ontology rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology">
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.0</owl:versionInfo>
        <rdfs:comment>An ontology about grocery items including their ingredients</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- http://xmlns.com/foaf/0.1/depiction -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/depiction"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/contains -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/contains">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/containsFoodStuff -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/containsFoodStuff">
        <rdfs:range rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
        <rdfs:subPropertyOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/contains"/>
    </owl:ObjectProperty>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient">
        <rdfs:domain rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
        <rdfs:range rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
        <rdfs:subPropertyOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/contains"/>
    </owl:ObjectProperty>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/hasProductType -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/hasProductType"/>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/hasSomething -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/hasSomething">
        <rdfs:domain rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/VitaminK"/>
    </owl:ObjectProperty>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/isLocatedIn -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/isLocatedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/isMadeIn -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/isMadeIn">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/isMadeIn"/>
            <rdf:Description rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/isLocatedIn"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/isSoldByStore -->

    <owl:ObjectProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/isSoldByStore">
        <rdfs:domain rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/GroceryItem"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/hasPrice -->

    <owl:DatatypeProperty rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/hasPrice">
        <rdfs:domain rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/GroceryItem"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2003/01/geo/wgs84_pos#lat -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#lat"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Almond -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Almond">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Nut"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/AlphaTocopherolAcetate -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/AlphaTocopherolAcetate">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Vitamer"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/AmaranthFlour -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/AmaranthFlour">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Flour"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/AmmoniumBicarbonate -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/AmmoniumBicarbonate">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Apple -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Apple">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FruitProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/BackToNatureFudgeMintCookies -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/BackToNatureFudgeMintCookies">
        <rdfs:label>Back To Nature Fudge Mint Cookies</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/GroceryItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/containsFoodStuff"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FudgeMintCookie"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/BananaPuree -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/BananaPuree">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FruitProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Barley -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Barley">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/CerealGrain"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/BiscoffCookie -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/BiscoffCookie">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Cookie"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/SodiumBicarbonate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/SoyFlour"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/BrownSugar"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CanolaOil"/>
                            <rdf:Description rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/PalmOil"/>
                            <rdf:Description rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/SoyBeanOil"/>
                            <rdf:Description rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/SunflowerOil"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/WheatFlour"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Salt"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Cinnamon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/BrownFlour -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/BrownFlour">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/WheatFlour"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/BrownRiceFlour -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/BrownRiceFlour">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/RiceFlour"/>
        <owl:disjointWith rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/WholeGrainBrownRiceFlour"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/BrownSugar -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/BrownSugar">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/SugarProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Buckwheat -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Buckwheat">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Wheat"/>
        <owl:disjointWith rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/HardRedWheat"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Butter -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Butter">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/ButterProduct"/>
        <owl:disjointWith rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/CocoaButter"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/ButterProduct -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/ButterProduct">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/DairyProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CalciumCarbonate -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CalciumCarbonate">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/MineralNutrient"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CaneSyrup -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CaneSyrup">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodSyrup"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CanolaOil -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CanolaOil">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/VegetableOil"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Cashew -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Cashew">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Nut"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CerealGrain -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CerealGrain">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/ChiaFlour -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/ChiaFlour">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Flour"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/ChiaSeed -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/ChiaSeed">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/ChickenEgg -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/ChickenEgg">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Egg"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/ChocolateLiquor -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/ChocolateLiquor">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/ChocolateProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/ChocolateProduct -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/ChocolateProduct">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Cinnamon -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Cinnamon">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Spice"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CocoaButter -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CocoaButter">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/ButterProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CocoaProduct -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CocoaProduct">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Coconut -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Coconut">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FruitProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Continent -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Continent"/>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Cookie -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Cookie">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CornSyrup -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CornSyrup">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodSyrup"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Cornstarch -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Cornstarch">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/GrainStarch"/>
        <owl:disjointWith rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/WheatStarch"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CostcoStore -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CostcoStore">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Store"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CottonSeedOil -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CottonSeedOil">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/VegetableOil"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Country -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Country"/>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/CreamOfTartre -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/CreamOfTartre">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/DairyProduct -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/DairyProduct">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/DehydratedCaneJuice -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/DehydratedCaneJuice">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/SugarProduct"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/DriedCaneSyrup -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/DriedCaneSyrup">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/CaneSyrup"/>
        <owl:disjointWith rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/InvertCaneSyrup"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/DutchedCocoa -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/DutchedCocoa">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/CocoaProduct"/>
        <owl:disjointWith rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/NaturalCocoa"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/Egg -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/Egg">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FoodStuff"/>
    </owl:Class>
    


    <!-- http://protege.stanford.edu/ontologies/grocery-ontology/EnrichedWheatFlour -->

    <owl:Class rdf:about="http://protege.stanford.edu/ontologies/grocery-ontology/EnrichedWheatFlour">
        <rdfs:subClassOf rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/Flour"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/FolicAcid"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://protege.stanford.edu/ontologies/grocery-ontology/ThiaminMononitrate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
