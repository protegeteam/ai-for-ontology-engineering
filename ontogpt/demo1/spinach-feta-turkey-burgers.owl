    <!-- https://www.allrecipes.com/recipe/158968/spinach-and-feta-turkey-burgers -->

    <owl:Class rdf:about="https://www.allrecipes.com/recipe/158968/spinach-and-feta-turkey-burgers">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://w3id.org/ontogpt/recipe/Recipe"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002420"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://w3id.org/ontogpt/recipe/amount"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="http://qudt.org/schema/qudt/unit"/>
                                                        <owl:someValuesFrom rdf:resource="http://example.org/auto/cloves"/>
                                                    </owl:Restriction>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="http://w3id.org/ontogpt/recipe/value"/>
                                                        <owl:hasValue>2</owl:hasValue>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                    <owl:Restriction>
