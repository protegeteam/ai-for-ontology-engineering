                                                    </owl:Restriction>
                                                    <owl:Restriction>
                                                        <owl:onProperty rdf:resource="http://w3id.org/ontogpt/recipe/state"/>
                                                        <owl:hasValue>whole</owl:hasValue>
                                                    </owl:Restriction>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
