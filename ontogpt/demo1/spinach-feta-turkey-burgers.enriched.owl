    <!-- http://purl.obolibrary.org/obo/BFO_0000051 -->

    <ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000051">
        <obo:IAO_0000115>a core relation that holds between a whole and its part</obo:IAO_0000115>
        <oboInOwl:hasDbXref>BFO:0000051</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>has_part</oboInOwl:hasExactSynonym>
        <oboInOwl:id>has_part</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_go_annotation_extension"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_go_ontology"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_gocam"/>
        <oboInOwl:shorthand>has_part</oboInOwl:shorthand>
        <rdfs:label>has part</rdfs:label>
    </ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00002420 -->

    <ObjectProperty rdf:about="http://purl.obolibrary.org/obo/FOODON_00002420">
        <obo:IAO_0000115>A relation attaching between a food material and another food material that has been added to it at some point in its history.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>FOODON:00002420</oboInOwl:hasDbXref>
        <oboInOwl:id>has_ingredient</oboInOwl:id>
        <oboInOwl:shorthand>has_ingredient</oboInOwl:shorthand>
        <rdfs:label>has ingredient</rdfs:label>
    </ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002233 -->

    <ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002233">
        <obo:IAO_0000115>p has input c iff: p is a process, c is a material entity, c is a participant in p, c is present at the start of p, and the state of c is modified during p.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>RO:0002233</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>consumes</oboInOwl:hasExactSynonym>
        <oboInOwl:id>has_input</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/TEMP#ro-eco"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_go_annotation_extension"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_go_ontology"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_gocam"/>
        <oboInOwl:shorthand>has_input</oboInOwl:shorthand>
        <rdfs:label>has input</rdfs:label>
    </ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002234 -->

    <ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002234">
        <obo:IAO_0000115>p has output c iff c is a participant in p, c is present at the end of p, and c is not present in the same state at the beginning of p.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>RO:0002234</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>produces</oboInOwl:hasExactSynonym>
        <oboInOwl:id>has_output</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/TEMP#ro-eco"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_go_annotation_extension"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_go_ontology"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/obo_#valid_for_gocam"/>
        <oboInOwl:shorthand>has_output</oboInOwl:shorthand>
        <rdfs:label>has output</rdfs:label>
    </ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002500 -->

    <ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002500">
        <obo:IAO_0000115>A relationship between a material entity and a process where the material entity has some causal role that influences the process</obo:IAO_0000115>
        <oboInOwl:hasDbXref>RO:0002500</oboInOwl:hasDbXref>
        <oboInOwl:id>causal_agent_in_process</oboInOwl:id>
        <oboInOwl:shorthand>causal_agent_in_process</oboInOwl:shorthand>
        <rdfs:label>causal agent in process</rdfs:label>
    </ObjectProperty>
    


