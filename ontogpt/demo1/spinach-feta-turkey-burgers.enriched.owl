        <oboInOwl:hasRelatedSynonym>shoot (related)</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>thalli (related, plural)</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>thallus (related)</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>PO:0009006</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/TEMP#TraitNet%3E"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/TEMP#reference%3E"/>
        <rdfs:label>shoot system</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/PO_0009008 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/PO_0009008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PO_0025496"/>
        <obo:IAO_0000115>A multi-tissue plant structure (PO:0025496) that is a functional unit, is a proper part of a whole plant (PO:0000003), and includes portions of plant tissue (PO:0009007) of at least two different types that derive from a common developmental path.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>organ (broad)</oboInOwl:hasBroadSynonym>
