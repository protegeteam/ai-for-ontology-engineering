    <!-- http://purl.obolibrary.org/obo/FOODON_00002222 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00002222">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001180"/>
        <obo:IAO_0000115>A sandwich food product is a food product used to create a sandwich.  This includes bread as a container, and sandwich ingredients and spreads.</obo:IAO_0000115>
        <oboInOwl:id>FOODON:00002222</oboInOwl:id>
        <rdfs:label>sandwich food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00002403 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00002403">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <obo:IAO_0000115>Any substance that can be consumed by an organism to satisfy nutritional or other health needs, or to provide a social or organoleptic food experience</obo:IAO_0000115>
