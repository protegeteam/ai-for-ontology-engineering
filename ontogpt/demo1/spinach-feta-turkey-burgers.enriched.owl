        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03430151"/>
        <obo:IAO_0000115>A patty, in American, Canadian, South African, Australian and New Zealand English, is a flattened, usually round, serving of ground food, often meat or meat alternatives. The food is compacted and shaped into the patty, then cooked, and served.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>pattie</oboInOwl:hasExactSynonym>
        <oboInOwl:id>FOODON:00002951</oboInOwl:id>
        <rdfs:label>patties</rdfs:label>
        <rdfs:label>patty</rdfs:label>
    </Class>
    


