    <!-- http://purl.obolibrary.org/obo/FOODON_03411236 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_03411236">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002616"/>
        <obo:IAO_0000115>The turkey is a large bird in the genus Meleagris, which is native to the Americas. Males of both turkey species have a distinctive fleshy wattle or protuberance that hangs from the top of the beak (called a snood). They are among the largest birds in their ranges. As in many galliformes, the male is larger and much more colorful than the female.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>turkey</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>&lt;http://eol.org/pages/18523&gt;</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>&lt;http://www.langual.org/langual_thesaurus.asp?termid=B1236&gt;</oboInOwl:hasDbXref>
        <oboInOwl:id>FOODON:03411236</oboInOwl:id>
        <rdfs:label>turkey (bird)</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_03411297 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_03411297">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00003004"/>
        <obo:IAO_0000115>A vertebrate animal is any species of organism within the subphylum Vertebrata (chordates with backbones). Vertebrates represent the overwhelming majority of the phylum Chordata, with currently about 69,276 species described.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>animal</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>&lt;http://www.langual.org/langual_thesaurus.asp?termid=B1297&gt;</oboInOwl:hasDbXref>
        <oboInOwl:id>FOODON:03411297</oboInOwl:id>
        <rdfs:label>vertebrate animal</rdfs:label>
    </Class>
    


