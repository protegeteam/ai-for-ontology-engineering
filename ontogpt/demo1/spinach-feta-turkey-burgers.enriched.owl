    <!-- http://purl.obolibrary.org/obo/PO_0009006 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/PO_0009006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PO_0025007"/>
        <obo:IAO_0000115>A collective plant organ structure (PO:0025007) that produces shoot-borne portions of meristem tissue (PO:0009013) and the plant structures (PO:0009011) that arise from them.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>FNA:02756ad4-a09c-48d7-8754-903254e557a9</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FNA:d1431b5c-7b86-46a0-8d3c-bd426fe12c85</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>PO_GIT:135</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>sistema de epiblasto (epiblastema) (Spanish, exact)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>シュート系、苗条系 (Japanese, exact)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym>tree crown (narrow)</oboInOwl:hasNarrowSynonym>
