        <oboInOwl:hasExactSynonym>植物 構造 (Japanese, exact)</oboInOwl:hasExactSynonym>
        <oboInOwl:id>PO:0009011</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/TEMP#TraitNet%3E"/>
