    <!-- http://purl.obolibrary.org/obo/FOODON_00001714 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001714">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002403"/>
