        <oboInOwl:hasExactSynonym>植物 器官 (Japanese, exact)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasRelatedSynonym>compound plant organ (related)</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>simple plant organ (related)</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>PO:0009008</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/TEMP#TraitNet%3E"/>
        <rdfs:label>plant organ</rdfs:label>
    </Class>
    


