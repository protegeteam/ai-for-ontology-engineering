    <!-- http://purl.obolibrary.org/obo/COB_0000082 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/COB_0000082">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <obo:IAO_0000115>A process that is initiated by an agent who intends to carry out a plan to achieve an objective through one or more actions as described in a plan specification.</obo:IAO_0000115>
        <oboInOwl:id>COB:0000082</oboInOwl:id>
        <rdfs:label>planned process</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001002 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00002403"/>
        <obo:IAO_0000115>Food material for humans and animals which is processed with the intention that it be consumable as a whole or added to other food products.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Foodon product type</oboInOwl:hasExactSynonym>
        <oboInOwl:id>FOODON:00001002</oboInOwl:id>
        <rdfs:label>food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001013 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001256"/>
        <obo:IAO_0000115>Cheese is a food derived from milk that is produced in a wide range of flavors, textures, and forms by coagulation of the milk protein casein.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>&lt;https://bioregistry.io/reference/siren:F1076&gt;</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Cheese</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>cheese</oboInOwl:hasExactSynonym>
        <oboInOwl:id>FOODON:00001013</oboInOwl:id>
        <rdfs:label>cheese food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001015 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001002"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00004331"/>
        <obo:IAO_0000115>A food product which has as a defining ingredient some plant material.</obo:IAO_0000115>
        <oboInOwl:id>FOODON:00001015</oboInOwl:id>
        <rdfs:label>plant food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001092 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001092">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00004242"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00005502"/>
        <obo:IAO_0000115>A food product which is derived from or produced by an animal that has a vertibrae.</obo:IAO_0000115>
        <oboInOwl:id>FOODON:00001092</oboInOwl:id>
        <rdfs:label>vertebrate food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001180 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001180">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03311737"/>
        <obo:IAO_0000115>Food product that is 1) ready or nearly ready for consumption; 2) usually a composite of several foods or ingredients that often belong to distinct product types; 3) usually formulated, mixed and partially or fully cooked.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>prepared</oboInOwl:hasBroadSynonym>
        <oboInOwl:id>FOODON:00001180</oboInOwl:id>
        <rdfs:label>prepared food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001242 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001242">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001015"/>
        <obo:IAO_0000115>A food product that has some spice or herb as a defining ingredient.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>&lt;http://www.langual.org/langual_thesaurus.asp?termid=H0151&gt;</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>herb or spice</oboInOwl:hasExactSynonym>
        <oboInOwl:id>FOODON:00001242</oboInOwl:id>
        <rdfs:label>spice or herb</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001256 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001256">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001092"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00005501"/>
        <obo:IAO_0000115>A dairy food product has mammilian milk or a milk component as an ingredient.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>&lt;http://www.langual.org/langual_thesaurus.asp?termid=H0242&gt;</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>dairy product</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>milk product</oboInOwl:hasExactSynonym>
        <oboInOwl:id>FOODON:00001256</oboInOwl:id>
        <rdfs:label>dairy food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001261 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001261">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001015"/>
        <obo:IAO_0000115>A plant food product which derives from one or more vegetables.</obo:IAO_0000115>
        <oboInOwl:id>FOODON:00001261</oboInOwl:id>
        <rdfs:label>vegetable food product</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001604 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001604">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_03301906"/>
        <obo:IAO_0000115>A sandwich which has at least one prominent meat ingredient.</obo:IAO_0000115>
        <oboInOwl:id>FOODON:00001604</oboInOwl:id>
        <rdfs:label>animal product sandwich</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001699 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001699">
